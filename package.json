{
  "name": "autocopy",
  "version": "1.0.0",
  "description": "社交媒体文案自动生成工具",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "build:frontend": "tsc -p public/src/tsconfig.json",
    "build:all": "npm run build && npm run build:frontend",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "web": "node dist/web/server.js",
    "dev:web": "ts-node src/web/server.ts",
    "dev:web:hot": "nodemon --watch src --ext ts --exec ts-node src/web/server.ts",
    "dev:frontend:watch": "tsc -p public/src/tsconfig.json --watch",
    "dev:full": "concurrently \"npm run dev:frontend:watch\" \"npm run dev:web:hot\"",
    "clean": "rimraf dist public/js"
  },
  "keywords": [
    "copywriting",
    "ai",
    "social-media",
    "deepseek",
    "web-ui"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^16.3.1",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14",
    "rimraf": "^5.0.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
