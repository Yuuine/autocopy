# DeepSeek API Configuration
DEEPSEEK_API_KEY=your_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# OpenAI API Configuration (Optional)
# OPENAI_API_KEY=your_openai_api_key
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4

# Claude API Configuration (Optional)
# ANTHROPIC_API_KEY=your_anthropic_api_key
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
# ANTHROPIC_MODEL=claude-3-opus-20240229

# Wenxin API Configuration (Optional)
# WENXIN_API_KEY=your_wenxin_api_key
# WENXIN_SECRET_KEY=your_wenxin_secret_key
# WENXIN_MODEL=ernie-bot-4

# Qwen API Configuration (Optional)
# QWEN_API_KEY=your_qwen_api_key
# QWEN_BASE_URL=https://dashscope.aliyuncs.com/api/v1
# QWEN_MODEL=qwen-turbo

# Gemini API Configuration (Optional)
# GEMINI_API_KEY=your_gemini_api_key
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# GEMINI_MODEL=gemini-pro

# Encryption Secret (Required for user API key storage)
# Generate a strong random string (at least 32 characters)
ENCRYPTION_SECRET=your_strong_encryption_secret_here

# Server Configuration
PORT=3000
